APP_ENV=development
SESSION_SECRET=byt-detta-i-prod-tack
DATABASE_PATH=./data/notarkiv.db
IMAGES_PATH=./data/images

# OCR
OCR_PROVIDER=claude_vision
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# Task queue
REDIS_URL=redis://localhost:6379/0

# MusicBrainz (kräver identifierande User-Agent)
MUSICBRAINZ_USER_AGENT=notarkiv/0.1 (din@email.tld)
MUSICBRAINZ_RATE_LIMIT_DELAY=1.0

# Observability
LOG_LEVEL=INFO
SENTRY_DSN=

# Bootstrap admin (skapas av db reset --seed om angiven)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=byt-detta-direkt
